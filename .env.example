# SUPABASE CONNECTION
# Used for the app (Transaction Pooler — port 6543, required for high concurrency Server Actions)
DATABASE_URL="postgresql://postgres:your_database_password@db.your_project_ref.supabase.co:6543/postgres?sslmode=require&pgbouncer=true"

# Used for migrations (Direct Connection — port 5432)
DIRECT_URL="postgresql://postgres:your_database_password@db.your_project_ref.supabase.co:5432/postgres?sslmode=require"

# Optional: protect /api/intake endpoint (recommended)
INTAKE_API_KEY="your_intake_api_key"

# CLERK AUTH
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your_clerk_publishable_key"
CLERK_SECRET_KEY="your_clerk_secret_key"

# GOD MODE: comma-separated Clerk user IDs with full admin access (optional)
GOD_MODE_USER_IDS="user_abc123,user_def456"

# MEMBERSHIP CONVERSION (optional)
NEXT_PUBLIC_MEMBERSHIP_CHECKOUT_URL="https://checkout.example.com/capital-architect"
NEXT_PUBLIC_TIER_B_STRIPE_URL="https://buy.stripe.com/example-tier-b"
NEXT_PUBLIC_MEMBERSHIP_BOOKING_URL="https://calendly.com/example/capital-architect-membership"
NEXT_PUBLIC_REPAIR_KIT_URL="https://capitalarchitect.tech/products/repair-kit"
NEXT_PUBLIC_MEMBERSHIP_CONTACT_EMAIL="support@capitalarchitect.tech"

# GEMINI API (optional)
GEMINI_API_KEY="your_gemini_api_key"

# RESEND EMAIL (required for blueprint delivery)
RESEND_API_KEY="re_123456789"

# STRIPE PAYMENTS (required for Funding Readiness Intensive)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ADMIN & AUTOMATION
ADMIN_ALERT_EMAIL="team@capitalarchitect.tech"
CRON_SECRET="your_cron_secret"
NEXT_PUBLIC_BASE_URL="https://capitalarchitect.tech"

# PLAYWRIGHT E2E (optional)
BASE_URL="http://localhost:3000"
CLERK_TESTING_TOKEN="your_clerk_testing_token"
