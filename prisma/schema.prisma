generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("SETTER")
  createdAt DateTime @default(now())
}

model Lead {
  id           String   @id @default(cuid())
  businessName String
  tier         String   @default("B")
  adb          Int
  nsfs         Int
  status       String   @default("PENDING_DOCS")
  createdAt    DateTime @default(now())
}