generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id                    String    @id
  businessName          String
  tier                  String    @default("B")
  adb                   Int       @default(0)
  nsfs                  Int       @default(0)
  status                String    @default("PENDING_DOCS")
  createdAt             DateTime  @default(now())
  email                 String?
  ficoScore             Int?
  lastContactedAt       DateTime?
  monthlyRevenue        Int?
  notes                 String?
  ownerName             String?
  phone                 String?
  source                String    @default("website")
  tags                  String[]  @default([])
  timeInBusiness        Int?
  updatedAt             DateTime  @default(now())
  chase524Count         Int?
  complianceStatus      String?
  entityType            String?
  fundabilityScore      Int?
  hasIdentityTheftBlock Boolean?
  metro2ErrorCount      Int?
  recentInquiries       Int?

  @@index([email])
  @@index([status])
  @@index([tier])
}

model User {
  id        String   @id
  email     String   @unique
  role      String   @default("SETTER")
  createdAt DateTime @default(now())
}

model CapitalLead {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  path            String
  fullName        String
  email           String
  phone           String?
  businessName    String?
  
  // Verdic Score Details
  score           Int
  tier            String
  hasMetro2Errors Boolean  @default(false)

  // Status
  hasPaid         Boolean  @default(false)
  
  // Storage for the exact intake answers
  rawInput        Json?

  @@map("capital_leads")
}
