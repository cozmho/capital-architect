generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id // Clerk User ID (user_...)
  email     String   @unique
  role      String   @default("SETTER")
  createdAt DateTime @default(now())
}

model Lead {
  id              String   @id @default(cuid())
  businessName    String
  ownerName       String?
  email           String?
  phone           String?
  
  // Financial Profile
  ficoScore       Int?
  monthlyRevenue  Int?
  timeInBusiness  Int?     // months
  
  // Tier & Status
  tier            String   @default("B")  // A, B, C, CHECK_MANUALLY
  status          String   @default("PENDING_DOCS")
  tags            String[] @default([])
  
  // Tracking Fields
  adb             Int      @default(0)
  nsfs            Int      @default(0)
  source          String   @default("website")
  notes           String?
  
  // Compliance Engine Fields
  metro2ErrorCount       Int?
  hasIdentityTheftBlock  Boolean?
  complianceStatus       String?
  
  // Underwriting Engine Fields
  chase524Count    Int?
  recentInquiries  Int?
  entityType       String?
  
  // Master Fundability Score
  fundabilityScore Int?

  // Verdic Engine Fields
  path            String?   // "business" | "pre-business"
  rawInput        Json?     // Full intake form answers for audit trail
  hasMetro2Errors Boolean?  // Explicit boolean from Verdic scoring

  // Payment Fields
  paidAmount       Int?       // Amount in cents
  paidAt           DateTime?
  stripeSessionId  String?    @unique
  stripeCustomerId String?
  paymentStatus    String?    // "pending" | "paid" | "failed" | "refunded"

  // Follow-up Automation
  followUpSentAt DateTime?
  followUpCount  Int        @default(0)

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  lastContactedAt DateTime?

  @@index([email])
  @@index([tier])
  @@index([status])
  @@index([paymentStatus])
  @@index([followUpSentAt])
}